<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SwiftDrop.Desktop.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        x:Class="SwiftDrop.Desktop.Views.MainWindow"
        Title="SwiftDrop" Width="980" Height="700"
        MinWidth="740" MinHeight="540"
        Background="#0d0d14">

	<Grid RowDefinitions="Auto,*">

		<!-- MENU BAR -->
		<Border Grid.Row="0" Background="#0a0a11"
                BorderBrush="#2a2a45" BorderThickness="0,0,0,1"
                IsVisible="{Binding IsLoggedIn}">
			<Menu Background="Transparent" Foreground="#8888aa">
				<MenuItem Header="File" Padding="10,5">
					<MenuItem Header="Settings" IsEnabled="False"
                              Foreground="#e8e8f0"/>
					<Separator/>
					<MenuItem Header="Quit" Command="{Binding QuitCommand}"
                              Foreground="#e8e8f0"/>
				</MenuItem>
				<MenuItem Header="Edit" Padding="10,5">
					<MenuItem Header="Copy" InputGesture="Ctrl+C"
                              Foreground="#e8e8f0"/>
					<MenuItem Header="Paste" InputGesture="Ctrl+V"
                              Foreground="#e8e8f0"/>
				</MenuItem>
				<MenuItem Header="View" Padding="10,5">
					<MenuItem Header="Refresh Users"
                              Command="{Binding RefreshUsersCommand}"
                              Foreground="#e8e8f0"/>
				</MenuItem>
				<MenuItem Header="Help" Padding="10,5">
					<MenuItem Header="About SwiftDrop" IsEnabled="False"
                              Foreground="#e8e8f0"/>
					<MenuItem Header="Version 0.1.0" IsEnabled="False"
                              Foreground="#6c7086"/>
				</MenuItem>
			</Menu>
		</Border>

		<Grid Grid.Row="1">

			<!-- LOGIN -->
			<Border IsVisible="{Binding !IsLoggedIn}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#1a1a2e" CornerRadius="16"
                    Padding="44,40" Width="400">
				<StackPanel Spacing="14">
					<StackPanel HorizontalAlignment="Center" Spacing="6">
						<Border Width="62" Height="62" CornerRadius="31"
                                Background="#7c5cbf"
                                HorizontalAlignment="Center">
							<TextBlock Text="⚡" FontSize="30"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<TextBlock Text="SwiftDrop" FontSize="26"
                                   FontWeight="Bold" Foreground="#e8e8f0"
                                   HorizontalAlignment="Center"/>
						<TextBlock Text="Fast. Simple. Yours."
                                   FontSize="12" Foreground="#555570"
                                   HorizontalAlignment="Center"/>
					</StackPanel>
					<TextBlock Text="{Binding StatusText}" FontSize="12"
                               Foreground="#43b581"
                               HorizontalAlignment="Center"/>
					<TextBlock Text="Username (register only)"
                               Foreground="#8888aa" FontSize="12"/>
					<TextBox Text="{Binding Username}"
                             PlaceholderText="Username"
                             Background="#252540" Foreground="#e8e8f0"
                             BorderBrush="#2a2a45" CornerRadius="8"
                             Padding="10,8"/>
					<TextBlock Text="Email" Foreground="#8888aa" FontSize="12"/>
					<TextBox Text="{Binding Email}"
                             PlaceholderText="email@example.com"
                             Background="#252540" Foreground="#e8e8f0"
                             BorderBrush="#2a2a45" CornerRadius="8"
                             Padding="10,8"/>
					<TextBlock Text="Password" Foreground="#8888aa"
                               FontSize="12"/>
					<TextBox Text="{Binding Password}"
                             PlaceholderText="Password" PasswordChar="*"
                             Background="#252540" Foreground="#e8e8f0"
                             BorderBrush="#2a2a45" CornerRadius="8"
                             Padding="10,8"/>
					<Button Content="Register"
                            Command="{Binding RegisterCommand}"
                            Background="#252540" Foreground="#e8e8f0"
                            BorderBrush="#7c5cbf" BorderThickness="1"
                            CornerRadius="8" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="0,10"/>
					<Button Content="Login"
                            Command="{Binding LoginCommand}"
                            Background="#7c5cbf" Foreground="#e8e8f0"
                            CornerRadius="8" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="0,10"/>
				</StackPanel>
			</Border>

			<!-- MAIN APP -->
			<Grid IsVisible="{Binding IsLoggedIn}"
                  ColumnDefinitions="270,*">

				<!-- SIDEBAR -->
				<Grid Grid.Column="0" RowDefinitions="Auto,*,Auto"
                      Background="#12121f">

					<!-- Sidebar top -->
					<Border Grid.Row="0" Padding="14,12"
                            Background="#0d0d14"
                            BorderBrush="#2a2a45"
                            BorderThickness="0,0,0,1">
						<Grid ColumnDefinitions="*,Auto">
							<TextBlock Grid.Column="0"
                                       Text="⚡ SwiftDrop"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#e8e8f0"
                                       VerticalAlignment="Center"/>
							<Button Grid.Column="1" Content="🔄"
                                    Command="{Binding RefreshUsersCommand}"
                                    Background="Transparent"
                                    Foreground="#555570" FontSize="14"
                                    ToolTip.Tip="Refresh users"/>
						</Grid>
					</Border>

					<!-- User list -->
					<ScrollViewer Grid.Row="1">
						<StackPanel>
							<!-- Starred section -->
							<StackPanel IsVisible="{Binding StarredUsers.Count,
                                Converter={x:Static vm:CountToBoolConverter.Instance}}">
								<Border Padding="14,8,14,4">
									<TextBlock Text="⭐ STARRED"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#555570"
                                               LetterSpacing="1.5"/>
								</Border>
								<ItemsControl ItemsSource="{Binding StarredUsers}"
                                              Name="StarredUserList">
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="vm:UserViewModel">
											<Border Padding="8,4" Margin="6,1"
                                                    CornerRadius="8" Cursor="Hand"
                                                    Background="{Binding IsSelected,
                                                        Converter={x:Static vm:BoolToBrushConverter.Instance}}">
												<Grid ColumnDefinitions="Auto,*,Auto">
													<Grid Grid.Column="0" Width="38"
                                                          Height="38" Margin="0,0,8,0">
														<Ellipse Fill="#252540"/>
														<TextBlock Text="{Binding AvatarLetter}"
                                                                   FontWeight="Bold"
                                                                   FontSize="15"
                                                                   Foreground="#e8e8f0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
														<Ellipse Width="11" Height="11"
                                                                 Fill="#43b581"
                                                                 IsVisible="{Binding IsOnline}"
                                                                 HorizontalAlignment="Right"
                                                                 VerticalAlignment="Bottom"/>
													</Grid>
													<StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Spacing="1">
														<TextBlock Text="{Binding Username}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#e8e8f0"
                                                                   FontSize="13"/>
														<TextBlock Text="{Binding LastMessage}"
                                                                   Foreground="#555570"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"/>
													</StackPanel>
												</Grid>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
								<Border Padding="14,8,14,4" Margin="0,4,0,0">
									<TextBlock Text="ALL MESSAGES"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#555570"
                                               LetterSpacing="1.5"/>
								</Border>
							</StackPanel>

							<!-- All users -->
							<Border Padding="14,8,14,4"
                                    IsVisible="{Binding !StarredUsers.Count,
                                        Converter={x:Static vm:CountToBoolConverter.Instance}}">
								<TextBlock Text="DIRECT MESSAGES"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#555570"
                                           LetterSpacing="1.5"/>
							</Border>
							<ItemsControl ItemsSource="{Binding Users}"
                                          Name="UserList">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="vm:UserViewModel">
										<Border Padding="8,4" Margin="6,1"
                                                CornerRadius="8" Cursor="Hand"
                                                Background="{Binding IsSelected,
                                                    Converter={x:Static vm:BoolToBrushConverter.Instance}}">
											<Grid ColumnDefinitions="Auto,*,Auto,Auto">
												<!-- Avatar -->
												<Grid Grid.Column="0" Width="38"
                                                      Height="38" Margin="0,0,8,0">
													<Ellipse Fill="#252540"/>
													<TextBlock Text="{Binding AvatarLetter}"
                                                               FontWeight="Bold"
                                                               FontSize="15"
                                                               Foreground="#e8e8f0"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
													<Ellipse Width="11" Height="11"
                                                             Fill="#43b581"
                                                             IsVisible="{Binding IsOnline}"
                                                             HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom"/>
												</Grid>
												<!-- Info -->
												<StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Spacing="1">
													<TextBlock Text="{Binding Username}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#e8e8f0"
                                                               FontSize="13"/>
													<TextBlock Text="{Binding LastMessage}"
                                                               Foreground="#555570"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"/>
												</StackPanel>
												<!-- Star button -->
												<Button Grid.Column="2"
                                                        Content="{Binding IsStarred,
                                                            Converter={x:Static vm:BoolToStarConverter.Instance}}"
                                                        Background="Transparent"
                                                        Foreground="#555570"
                                                        FontSize="13" Padding="2"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleStarCommand}"
                                                        CommandParameter="{Binding}"/>
												<!-- Unread badge -->
												<Border Grid.Column="3"
                                                        Background="#7c5cbf"
                                                        CornerRadius="10"
                                                        Padding="5,1"
                                                        IsVisible="{Binding HasUnread}"
                                                        VerticalAlignment="Center">
													<TextBlock Text="{Binding UnreadCount}"
                                                               Foreground="#e8e8f0"
                                                               FontSize="10"
                                                               FontWeight="Bold"/>
												</Border>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</ScrollViewer>

					<!-- CURRENT USER PROFILE (bottom-left like Discord) -->
					<Border Grid.Row="2" Background="#0d0d14"
                            BorderBrush="#2a2a45" BorderThickness="0,1,0,0"
                            Padding="10,8">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<!-- Avatar -->
							<Border Grid.Column="0" Width="36" Height="36"
                                    CornerRadius="18" Background="#7c5cbf"
                                    Margin="0,0,8,0">
								<TextBlock Text="{Binding CurrentUserAvatarLetter}"
                                           FontWeight="Bold" FontSize="15"
                                           Foreground="#e8e8f0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
							</Border>
							<!-- Info -->
							<StackPanel Grid.Column="1"
                                        VerticalAlignment="Center" Spacing="1">
								<TextBlock Text="{Binding CurrentUser.Username,
                                               FallbackValue='...'}"
                                           FontWeight="SemiBold"
                                           Foreground="#e8e8f0" FontSize="13"/>
								<StackPanel Orientation="Horizontal" Spacing="4">
									<Ellipse Width="7" Height="7" Fill="#43b581"
                                             VerticalAlignment="Center"/>
									<TextBlock Text="{Binding CurrentUser.Email,
                                                   FallbackValue='...'}"
                                               Foreground="#555570" FontSize="10"
                                               TextTrimming="CharacterEllipsis"/>
								</StackPanel>
							</StackPanel>
							<!-- Settings button -->
							<Button Grid.Column="2" Content="⚙"
                                    Background="Transparent"
                                    Foreground="#555570" FontSize="16"
                                    ToolTip.Tip="Settings"
                                    IsEnabled="False"/>
						</Grid>
					</Border>
				</Grid>

				<!-- CHAT AREA -->
				<Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto,Auto"
                      Background="#1a1a2e">

					<!-- Chat header -->
					<Border Grid.Row="0" Background="#12121f"
                            Padding="16,10"
                            BorderBrush="#2a2a45"
                            BorderThickness="0,0,0,1">
						<StackPanel Orientation="Horizontal" Spacing="10">
							<TextBlock Text="💬" FontSize="15"
                                       VerticalAlignment="Center"/>
							<TextBlock Text="{Binding SelectedUser.Username,
                                           FallbackValue='Select a conversation'}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="#e8e8f0"
                                       VerticalAlignment="Center"/>
							<Border CornerRadius="6" Padding="6,2"
                                    Background="#1a3a2a"
                                    IsVisible="{Binding SelectedUser.IsOnline}">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<Ellipse Width="7" Height="7"
                                             Fill="#43b581"
                                             VerticalAlignment="Center"/>
									<TextBlock Text="Online"
                                               Foreground="#43b581"
                                               FontSize="11"/>
								</StackPanel>
							</Border>
						</StackPanel>
					</Border>

					<!-- MESSAGES — takes remaining space -->
					<ScrollViewer Grid.Row="1" Name="MessageScroller"
                                  Padding="14,8"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
						<ItemsControl ItemsSource="{Binding CurrentMessages}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:MessageViewModel">
									<Grid Margin="0,1">

										<!-- OWN MESSAGES -->
										<StackPanel
                                            IsVisible="{Binding IsOwnMessage}"
                                            HorizontalAlignment="Right"
                                            Margin="60,0,0,0"
                                            Spacing="1">

											<!-- Header (only shown for first in group) -->
											<StackPanel
                                                IsVisible="{Binding ShowHeader}"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Spacing="6" Margin="0,6,0,2">
												<TextBlock Text="{Binding TimeDisplay}"
                                                           Foreground="#555570"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"/>
												<TextBlock Text="{Binding SenderName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#4a90d9"/>
											</StackPanel>

											<!-- Reply preview -->
											<Border IsVisible="{Binding HasReply}"
                                                    Background="#0d2a3a"
                                                    CornerRadius="6" Padding="8,4"
                                                    Margin="0,0,0,2"
                                                    HorizontalAlignment="Right">
												<StackPanel Spacing="1">
													<TextBlock
                                                        Text="{Binding ReplyTo.SenderName}"
                                                        FontSize="10"
                                                        FontWeight="Bold"
                                                        Foreground="#4a90d9"/>
													<TextBlock
                                                        Text="{Binding ReplyTo.Content}"
                                                        FontSize="11"
                                                        Foreground="#8888aa"
                                                        TextTrimming="CharacterEllipsis"
                                                        MaxWidth="200"/>
												</StackPanel>
											</Border>

											<!-- Text bubble -->
											<Border IsVisible="{Binding IsTextMessage}"
                                                    Background="#1a3a5c"
                                                    CornerRadius="14,14,2,14"
                                                    Padding="12,8">
												<StackPanel Spacing="3">
													<TextBlock Text="{Binding Content}"
                                                               Foreground="#e8e8f0"
                                                               TextWrapping="Wrap"
                                                               FontSize="13"/>
													<StackPanel
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        Spacing="4"
                                                        IsVisible="{Binding IsGrouped,
                                                            Converter={x:Static vm:InverseBoolConverter.Instance}}">
														<TextBlock
                                                            Text="{Binding TimeDisplay}"
                                                            Foreground="#555570"
                                                            FontSize="9"/>
														<TextBlock
                                                            Text="{Binding StatusIcon}"
                                                            FontSize="9"
                                                            Foreground="#4a90d9"/>
														<TextBlock Text="edited"
                                                                   FontSize="9"
                                                                   Foreground="#555570"
                                                                   IsVisible="{Binding IsEdited}"/>
													</StackPanel>
												</StackPanel>
											</Border>

											<!-- File card -->
											<Border IsVisible="{Binding IsFileMessage}"
                                                    Background="#1a3a5c"
                                                    CornerRadius="14,14,2,14"
                                                    Padding="12,10"
                                                    MinWidth="200">
												<Grid ColumnDefinitions="Auto,*">
													<Border Grid.Column="0"
                                                            Width="42" Height="42"
                                                            CornerRadius="10"
                                                            Background="#7c5cbf"
                                                            Margin="0,0,10,0">
														<TextBlock Text="⚡"
                                                                   FontSize="20"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
													</Border>
													<StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Spacing="2">
														<TextBlock Text="{Binding FileName}"
                                                                   Foreground="#e8e8f0"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>
														<TextBlock Text="{Binding FileSizeDisplay}"
                                                                   Foreground="#4a90d9"
                                                                   FontSize="11"/>
														<TextBlock Text="{Binding Content}"
                                                                   Foreground="#555570"
                                                                   FontSize="10"/>
													</StackPanel>
												</Grid>
											</Border>

											<!-- Image -->
											<Border IsVisible="{Binding IsImageMessage}"
                                                    CornerRadius="12,12,2,12"
                                                    ClipToBounds="True"
                                                    Cursor="Hand"
                                                    MaxWidth="300">
												<Image Source="{Binding MediaPath}"
                                                       MaxHeight="220"
                                                       Stretch="UniformToFill"/>
											</Border>

											<!-- Reactions -->
											<ItemsControl
                                                IsVisible="{Binding HasReactions}"
                                                ItemsSource="{Binding Reactions}"
                                                HorizontalAlignment="Right">
												<ItemsControl.ItemsPanel>
													<ItemsPanelTemplate>
														<StackPanel Orientation="Horizontal"
                                                                    Spacing="4"/>
													</ItemsPanelTemplate>
												</ItemsControl.ItemsPanel>
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="vm:ReactionViewModel">
														<Border Background="#252540"
                                                                CornerRadius="10"
                                                                Padding="6,2">
															<StackPanel Orientation="Horizontal"
                                                                        Spacing="3">
																<TextBlock Text="{Binding Emoji}"
                                                                           FontSize="12"/>
																<TextBlock Text="{Binding Count}"
                                                                           Foreground="#8888aa"
                                                                           FontSize="11"/>
															</StackPanel>
														</Border>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
										</StackPanel>

										<!-- THEIR MESSAGES -->
										<Grid IsVisible="{Binding !IsOwnMessage}"
                                              ColumnDefinitions="Auto,*"
                                              Margin="0,0,60,0">

											<!-- Avatar (only shown for first in group) -->
											<Grid Grid.Column="0" Width="36"
                                                  Height="36"
                                                  VerticalAlignment="Top"
                                                  Margin="0,20,8,0"
                                                  IsVisible="{Binding ShowHeader}">
												<Ellipse Fill="#252540"/>
												<TextBlock Text="{Binding AvatarLetter}"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           Foreground="#e8e8f0"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
											</Grid>

											<!-- Spacer when grouped (no avatar) -->
											<Grid Grid.Column="0" Width="44"
                                                  IsVisible="{Binding IsGrouped}"/>

											<StackPanel Grid.Column="1" Spacing="1">

												<!-- Header -->
												<StackPanel
                                                    IsVisible="{Binding ShowHeader}"
                                                    Orientation="Horizontal"
                                                    Spacing="6" Margin="0,6,0,2">
													<TextBlock Text="{Binding SenderName}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="#7c5cbf"/>
													<TextBlock Text="{Binding TimeDisplay}"
                                                               Foreground="#555570"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"/>
												</StackPanel>

												<!-- Reply preview -->
												<Border IsVisible="{Binding HasReply}"
                                                        Background="#1a1a2e"
                                                        CornerRadius="6"
                                                        Padding="8,4"
                                                        Margin="0,0,0,2">
													<StackPanel Spacing="1">
														<TextBlock
                                                            Text="{Binding ReplyTo.SenderName}"
                                                            FontSize="10"
                                                            FontWeight="Bold"
                                                            Foreground="#7c5cbf"/>
														<TextBlock
                                                            Text="{Binding ReplyTo.Content}"
                                                            FontSize="11"
                                                            Foreground="#8888aa"
                                                            TextTrimming="CharacterEllipsis"
                                                            MaxWidth="260"/>
													</StackPanel>
												</Border>

												<!-- Text bubble -->
												<Border IsVisible="{Binding IsTextMessage}"
                                                        Background="#252540"
                                                        CornerRadius="14,14,14,2"
                                                        Padding="12,8">
													<StackPanel Spacing="3">
														<TextBlock Text="{Binding Content}"
                                                                   Foreground="#e8e8f0"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="13"/>
														<StackPanel
                                                            Orientation="Horizontal"
                                                            Spacing="4"
                                                            IsVisible="{Binding IsGrouped,
                                                                Converter={x:Static vm:InverseBoolConverter.Instance}}">
															<TextBlock
                                                                Text="{Binding TimeDisplay}"
                                                                Foreground="#555570"
                                                                FontSize="9"/>
															<TextBlock Text="edited"
                                                                       FontSize="9"
                                                                       Foreground="#555570"
                                                                       IsVisible="{Binding IsEdited}"/>
														</StackPanel>
													</StackPanel>
												</Border>

												<!-- File card -->
												<Border IsVisible="{Binding IsFileMessage}"
                                                        Background="#252540"
                                                        CornerRadius="14,14,14,2"
                                                        Padding="12,10"
                                                        MinWidth="200">
													<Grid ColumnDefinitions="Auto,*">
														<Border Grid.Column="0"
                                                                Width="42" Height="42"
                                                                CornerRadius="10"
                                                                Background="#7c5cbf"
                                                                Margin="0,0,10,0">
															<TextBlock Text="⚡"
                                                                       FontSize="20"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
														</Border>
														<StackPanel Grid.Column="1"
                                                                    VerticalAlignment="Center"
                                                                    Spacing="4">
															<TextBlock Text="{Binding FileName}"
                                                                       Foreground="#e8e8f0"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"/>
															<TextBlock Text="{Binding FileSizeDisplay}"
                                                                       Foreground="#8888aa"
                                                                       FontSize="11"/>
															<Button Content="⬇ Download"
                                                                    Background="#7c5cbf"
                                                                    Foreground="#e8e8f0"
                                                                    CornerRadius="6"
                                                                    Padding="10,4"
                                                                    FontSize="12"
                                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DownloadCommand}"
                                                                    CommandParameter="{Binding}"/>
														</StackPanel>
													</Grid>
												</Border>

												<!-- Image -->
												<Border IsVisible="{Binding IsImageMessage}"
                                                        CornerRadius="12,12,12,2"
                                                        ClipToBounds="True"
                                                        Cursor="Hand"
                                                        MaxWidth="300">
													<Image Source="{Binding MediaPath}"
                                                           MaxHeight="220"
                                                           Stretch="UniformToFill"/>
												</Border>

												<!-- Reactions -->
												<ItemsControl
                                                    IsVisible="{Binding HasReactions}"
                                                    ItemsSource="{Binding Reactions}">
													<ItemsControl.ItemsPanel>
														<ItemsPanelTemplate>
															<StackPanel
                                                                Orientation="Horizontal"
                                                                Spacing="4"/>
														</ItemsPanelTemplate>
													</ItemsControl.ItemsPanel>
													<ItemsControl.ItemTemplate>
														<DataTemplate x:DataType="vm:ReactionViewModel">
															<Border Background="#252540"
                                                                    CornerRadius="10"
                                                                    Padding="6,2">
																<StackPanel
                                                                    Orientation="Horizontal"
                                                                    Spacing="3">
																	<TextBlock
                                                                        Text="{Binding Emoji}"
                                                                        FontSize="12"/>
																	<TextBlock
                                                                        Text="{Binding Count}"
                                                                        Foreground="#8888aa"
                                                                        FontSize="11"/>
																</StackPanel>
															</Border>
														</DataTemplate>
													</ItemsControl.ItemTemplate>
												</ItemsControl>

												<!-- Action buttons (reply, react) -->
												<StackPanel Orientation="Horizontal"
                                                            Spacing="4"
                                                            IsVisible="{Binding ShowHeader}">
													<Button Content="↩ Reply"
                                                            Background="Transparent"
                                                            Foreground="#555570"
                                                            FontSize="10"
                                                            Padding="4,2"
                                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ReplyCommand}"
                                                            CommandParameter="{Binding}"/>
													<Button Content="😊"
                                                            Background="Transparent"
                                                            Foreground="#555570"
                                                            FontSize="12"
                                                            Padding="4,2"
                                                            ToolTip.Tip="React"/>
												</StackPanel>
											</StackPanel>
										</Grid>

									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>

					<!-- Progress bar -->
					<ProgressBar Grid.Row="2"
                                 Value="{Binding TransferProgress}"
                                 Minimum="0" Maximum="100" Height="2"
                                 Background="Transparent"
                                 Foreground="#7c5cbf"/>

					<!-- Reply preview bar -->
					<Border Grid.Row="3"
                            IsVisible="{Binding IsReplying}"
                            Background="#12121f"
                            BorderBrush="#7c5cbf"
                            BorderThickness="0,0,0,0"
                            Padding="14,6">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<TextBlock Grid.Column="0" Text="↩"
                                       Foreground="#7c5cbf" FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
							<StackPanel Grid.Column="1" Spacing="1">
								<TextBlock Text="{Binding ReplyingTo.SenderName}"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#7c5cbf"/>
								<TextBlock Text="{Binding ReplyingTo.Content}"
                                           FontSize="11" Foreground="#8888aa"
                                           TextTrimming="CharacterEllipsis"/>
							</StackPanel>
							<Button Grid.Column="2" Content="✕"
                                    Command="{Binding CancelReplyCommand}"
                                    Background="Transparent"
                                    Foreground="#555570" FontSize="13"/>
						</Grid>
					</Border>

					<!-- INPUT BAR -->
					<Border Grid.Row="4" Background="#12121f"
                            BorderBrush="#2a2a45" BorderThickness="0,1,0,0"
                            Padding="12,10">
						<Grid ColumnDefinitions="*,Auto,Auto">
							<TextBox Grid.Column="0"
                                     Text="{Binding MessageInput}"
                                     PlaceholderText="Message..."
                                     Background="#252540"
                                     Foreground="#e8e8f0"
                                     BorderBrush="#2a2a45"
                                     CornerRadius="10" Padding="12,9"
                                     AcceptsReturn="False"
                                     Name="MessageInputBox"/>
							<Button Grid.Column="1" Content="📎"
                                    Command="{Binding SendFileCommand}"
                                    Background="Transparent"
                                    Foreground="#8888aa"
                                    Margin="8,0,4,0" FontSize="20"
                                    ToolTip.Tip="Attach file or image"/>
							<Button Grid.Column="2" Content="Send"
                                    Command="{Binding SendCommand}"
                                    Background="#7c5cbf"
                                    Foreground="#e8e8f0"
                                    CornerRadius="10" Padding="18,9"
                                    FontWeight="SemiBold"/>
						</Grid>
					</Border>
				</Grid>
			</Grid>
		</Grid>
	</Grid>
</Window>